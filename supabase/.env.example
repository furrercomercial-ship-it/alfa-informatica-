# Alfa Informática — placeholders das variáveis usadas pelas Edge Functions
# de pagamento (mp-create-payment, mp-webhook). NENHUM valor real vai aqui.
#
# Em produção (deployado), essas variáveis não vêm de arquivo nenhum — são
# configuradas uma vez, no seu computador, com:
#   supabase secrets set MP_ACCESS_TOKEN=SEU_ACCESS_TOKEN_DE_TESTE
#   supabase secrets set MP_WEBHOOK_SECRET=SEU_SEGREDO_DE_WEBHOOK
#   supabase secrets set SUPABASE_SERVICE_ROLE_KEY=SUA_SERVICE_ROLE_KEY
#
# Este arquivo só é útil se você quiser rodar as functions localmente pra
# testar antes de fazer deploy, com:
#   cp supabase/.env.example supabase/.env   (e aí sim preenche os valores)
#   supabase functions serve --env-file supabase/.env
#
# supabase/.env (sem .example) já está no .gitignore — nunca vai ser commitado.

SUPABASE_URL=https://ybkgevyahpkkxhiexejy.supabase.co
SUPABASE_SERVICE_ROLE_KEY=COLOCAR_SERVICE_ROLE_KEY_AQUI
MP_ACCESS_TOKEN=COLOCAR_ACCESS_TOKEN_DE_TESTE_AQUI
MP_WEBHOOK_SECRET=COLOCAR_SEGREDO_DO_WEBHOOK_AQUI
